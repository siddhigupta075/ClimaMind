<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:card_view="http://schemas.android.com/apk/res-auto"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient">

    <LinearLayout
        android:orientation="vertical"
        android:padding="20dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- CITY -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/cityText"
            android:text="Lucknow"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="16dp"/>

        <!-- HERO WEATHER CARD -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            card_view:cardCornerRadius="28dp"
            android:elevation="12dp"
            android:background="@drawable/weather_card_bg">

            <LinearLayout
                android:background="@drawable/weather_card_bg"
                android:orientation="vertical"
                android:padding="24dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:id="@+id/tempText"
                    android:text="28°C"
                    android:textSize="46sp"
                    android:letterSpacing="0.02"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:id="@+id/feelsLike"
                    android:text="Feels like 30°C"
                    android:textColor="#D1D5DB"
                    android:textSize="14sp"
                    android:layout_marginTop="4dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:id="@+id/weatherCondition"
                    android:text="☀️ Clear Sky"
                    android:textColor="#E0F2FE"
                    android:textSize="15sp"
                    android:layout_marginTop="8dp"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- SUGGESTION CARD -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            card_view:cardCornerRadius="24dp"
            android:elevation="10dp"
            app:cardBackgroundColor="@android:color/transparent">

            <LinearLayout
                android:background="@drawable/glass_bg"
                android:orientation="vertical"
                android:padding="20dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="AI Suggestion"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:id="@+id/suggestionText"
                    android:text="Tap below to get suggestion"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSuggest"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:text="Get Smart Suggestion"
                    android:textColor="#FFFFFF"
                    android:textAllCaps="false"
                    android:layout_marginTop="14dp"

                    android:background="@drawable/button_bg"

                    app:backgroundTint="@null"
                    android:elevation="8dp"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- MOOD CARD -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            card_view:cardCornerRadius="24dp"
            android:elevation="10dp"
            app:cardBackgroundColor="@android:color/transparent" >

            <LinearLayout
                android:background="@drawable/glass_bg"
                android:orientation="vertical"
                android:padding="20dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Daily Mood Index"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:layout_marginBottom="6dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:id="@+id/moodScore"
                    android:text="78 / 100 • Energetic"
                    android:textColor="#38BDF8"
                    android:textSize="20sp"
                    android:textStyle="bold"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- LAST UPDATED -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/lastUpdated"
            android:text="Updated just now"
            android:textColor="#64748B"
            android:textSize="12sp"
            android:gravity="center"
            android:layout_marginTop="10dp"
            android:alpha="0.7"/>

        <!-- LOADER -->
        <ProgressBar
            android:id="@+id/loader"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="gone"
            android:layout_marginTop="20dp"/>

    </LinearLayout>
</ScrollView>