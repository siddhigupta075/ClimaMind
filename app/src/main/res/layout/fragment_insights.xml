<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:card_view="http://schemas.android.com/apk/res-auto"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"

    android:background="@drawable/bg_gradient">

    <LinearLayout
        android:orientation="vertical"
        android:padding="20dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- TITLE -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Insights"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Your weather intelligence"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="20dp"/>

        <!-- HERO CARD (AVG TEMP) -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            card_view:cardCornerRadius="28dp"
            app:cardBackgroundColor="@android:color/transparent"
            android:elevation="12dp"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:orientation="vertical"
                android:background="@drawable/glass_bg"
                android:padding="24dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Average Temperature"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:id="@+id/avgTemp"
                    android:text="28°C"
                    android:textSize="36sp"
                    android:textStyle="bold"
                    android:textColor="#38BDF8"
                    android:layout_marginTop="6dp"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ROW: BEST + WORST -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp">

            <!-- BEST -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                app:cardBackgroundColor="@android:color/transparent"
                card_view:cardCornerRadius="22dp"
                android:elevation="8dp">

                <LinearLayout
                    android:orientation="vertical"
                    android:background="@drawable/glass_bg"
                    android:padding="18dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Best Time"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:id="@+id/bestTime"
                        android:text="6 PM"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#22C55E"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- WORST -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                app:cardBackgroundColor="@android:color/transparent"
                card_view:cardCornerRadius="22dp"
                android:elevation="8dp">

                <LinearLayout
                    android:orientation="vertical"
                    android:background="@drawable/glass_bg"
                    android:padding="18dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Avoid"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:id="@+id/worstTime"
                        android:text="2 PM"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#EF4444"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>

        <!-- INSIGHT CARD -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@android:color/transparent"
            card_view:cardCornerRadius="24dp"
            android:elevation="10dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:orientation="vertical"
                android:background="@drawable/glass_bg"
                android:padding="20dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Insight"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:id="@+id/insightText"
                    android:text="Perfect weather for productivity and outdoor activities."
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:layout_marginTop="6dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- RECOMMENDATION -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@android:color/transparent"
            card_view:cardCornerRadius="24dp"
            android:elevation="10dp">

            <LinearLayout
                android:orientation="vertical"
                android:background="@drawable/glass_bg"
                android:padding="20dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Recommendation"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:id="@+id/recommendation"
                    android:text="Go out in evening, avoid afternoon heat."
                    android:textColor="#FACC15"
                    android:textSize="16sp"
                    android:layout_marginTop="6dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>